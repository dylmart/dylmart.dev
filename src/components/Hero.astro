---
import { SITE } from '../site.config';
---
<section class="hero grain">
  <div class="stars" aria-hidden="true">
    {[[8, 20, 0], [18, 60, 1], [30, 15, 2], [44, 70, 0.5], [55, 30, 1.4], [64, 78, 2.6], [78, 64, 0.8], [90, 12, 1.9]].map(
      ([x, y, d]) => <i style={`left:${x}%; top:${y}%; animation-delay:${d}s`} />
    )}
  </div>
  <div class="planet" aria-hidden="true"></div>
  <div class="ring" aria-hidden="true"></div>
  <div class="orbiter" aria-hidden="true"><b></b></div>
  <p class="hud">// SLO GROUND STATION · 35.28°N 120.66°W</p>
  <h1 class="display">Dylan <br />Martin<span>.</span></h1>
  <p class="tag">{SITE.tagline} This is the ship's log.</p>
  <a class="cta" href="/projects">See the projects</a>
</section>

<style>
  .hero { position: relative; overflow: hidden; padding: 4rem 1.75rem 5rem; }
  .stars i {
    position: absolute; width: 2px; height: 2px; border-radius: 50%;
    background: var(--text); animation: twinkle 4s ease-in-out infinite;
  }
  @keyframes twinkle { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.9; } }
  .planet {
    position: absolute; right: 6%; top: 18%; width: clamp(120px, 18vw, 210px); aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, var(--accent-bright), var(--accent) 55%, #8f1d14);
    box-shadow: 0 0 0 12px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .ring {
    position: absolute; right: 2%; top: 34%; width: clamp(190px, 28vw, 330px); height: clamp(44px, 7vw, 80px);
    border: 2.5px solid var(--neutral); border-radius: 50%; transform: rotate(-16deg); opacity: 0.55;
  }
  .orbiter {
    position: absolute; right: 9%; top: 12%; width: clamp(180px, 26vw, 300px); aspect-ratio: 1;
    animation: orbit 26s linear infinite;
  }
  .orbiter b {
    position: absolute; top: 0; left: 50%; width: 9px; height: 9px; border-radius: 50%;
    background: var(--text); box-shadow: 0 0 10px var(--text);
  }
  @keyframes orbit { to { transform: rotate(360deg); } }
  h1 { font-size: clamp(3rem, 9vw, 5.2rem); margin: 0.9rem 0 0; position: relative; z-index: 2; }
  h1 span { color: var(--accent); }
  .tag { max-width: 30rem; margin-top: 1.1rem; color: var(--text-dim); position: relative; z-index: 2; }
  .cta {
    display: inline-block; margin-top: 1.4rem; background: var(--accent); color: var(--bg);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.75rem;
    padding: 0.85rem 1.5rem; border-radius: 4px; text-decoration: none;
    position: relative; z-index: 2; transition: background 0.2s ease;
  }
  .cta:hover { background: var(--accent-bright); color: var(--bg); }
</style>
