---
import { SITE } from '../site.config';
---
<section class="hero grain">
  {/* Dylan's cusp signs: Taurus on the left, Gemini on the right. Stick
      figures follow the real asterisms; Aldebaran and Pollux get the accent
      tint because both really are orange giants. */}
  <svg class="constellation taurus" viewBox="0 0 100 80" aria-hidden="true">
    <g class="lines">
      <polyline points="8,4 40,24 48,31 56,38" />
      <polyline points="56,38 49,46 43,51 4,30" />
      <polyline points="56,38 68,58 82,68" />
    </g>
    <g class="stars">
      <circle cx="8" cy="4" r="1.6" />
      <circle cx="4" cy="30" r="1.3" />
      <circle cx="40" cy="24" r="1.1" />
      <circle cx="48" cy="31" r="1.1" />
      <circle cx="56" cy="38" r="1.3" />
      <circle cx="49" cy="46" r="1" />
      <circle class="giant" cx="43" cy="51" r="2.2" />
      <circle cx="68" cy="58" r="1" />
      <circle cx="82" cy="68" r="1.1" />
    </g>
  </svg>
  <svg class="constellation gemini" viewBox="0 0 70 80" aria-hidden="true">
    <g class="lines">
      <polyline points="22,4 24,18 18,36 14,52 8,64" />
      <polyline points="44,10 44,24 46,38 42,52 36,66" />
      <polyline points="24,18 44,24" />
    </g>
    <g class="stars">
      <circle cx="22" cy="4" r="1.6" />
      <circle class="giant" cx="44" cy="10" r="2.2" />
      <circle cx="24" cy="18" r="1" />
      <circle cx="44" cy="24" r="1" />
      <circle cx="18" cy="36" r="1.1" />
      <circle cx="46" cy="38" r="1.1" />
      <circle cx="14" cy="52" r="1" />
      <circle cx="42" cy="52" r="1" />
      <circle cx="8" cy="64" r="1.3" />
      <circle cx="36" cy="66" r="1.5" />
    </g>
  </svg>
  <div class="art" aria-hidden="true">
    <div class="ring back">
      <div class="orbiter">
        <div class="orbit-spin"><b></b></div>
      </div>
    </div>
    <div class="planet"></div>
    <div class="ring front">
      <div class="orbiter">
        <div class="orbit-spin"><b></b></div>
      </div>
    </div>
  </div>
  <p class="hud">// SLO GROUND STATION · 35.28°N 120.66°W</p>
  <h1 class="display">Dylan <br />Martin<span>.</span></h1>
  <p class="tag">{SITE.tagline} This is the ship's log.</p>
  <a class="cta" href="/projects">See the projects</a>
</section>

<style>
  .hero { position: relative; overflow: hidden; padding: 4rem 1.75rem 5rem; }
  .constellation {
    position: absolute; pointer-events: none; opacity: 0.5;
  }
  .constellation.taurus { left: clamp(0.5rem, 3vw, 3rem); top: 6%; width: clamp(110px, 18vw, 190px); }
  .constellation.gemini { right: clamp(1rem, 6vw, 6rem); bottom: 6%; width: clamp(90px, 15vw, 150px); }
  @media (max-width: 560px) {
    /* no clear sky for the bull on phones; the twins carry the detail */
    .constellation.taurus { display: none; }
  }
  .constellation .lines polyline {
    fill: none; stroke: var(--neutral); stroke-width: 1; vector-effect: non-scaling-stroke;
    opacity: 0.55;
  }
  .constellation .stars circle { fill: var(--text); animation: twinkle 4s ease-in-out infinite; }
  .constellation .stars circle:nth-child(2n) { animation-delay: 1.3s; }
  .constellation .stars circle:nth-child(3n) { animation-delay: 2.4s; }
  .constellation .stars circle.giant { fill: var(--accent); animation-delay: 0.6s; }
  @keyframes twinkle { 0%, 100% { opacity: 0.35; } 50% { opacity: 1; } }
  /* One container owns the composition: every piece is centered on it,
     so planet, orbit line, and moving dot stay aligned at every width. */
  .art {
    position: absolute; right: clamp(0.5rem, 4vw, 4rem); top: clamp(1.5rem, 6vw, 3.5rem);
    width: clamp(180px, 30vw, 330px); aspect-ratio: 1;
    pointer-events: none;
  }
  .planet {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    width: 58%; aspect-ratio: 1; border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, var(--accent-bright), var(--accent) 55%, color-mix(in srgb, var(--accent) 45%, black));
    box-shadow: 0 0 0 12px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  /* The ring IS the orbit line: a tilted ellipse the dot travels along.
     Two synced copies give real depth: the full one sits behind the planet,
     the front one is clipped to the lower (near) half and draws over it. */
  .ring {
    position: absolute; left: 50%; top: 50%; width: 100%; height: 26%;
    transform: translate(-50%, -50%) rotate(-16deg);
    border: 2.5px solid var(--neutral); border-radius: 50%; opacity: 0.55;
  }
  .ring.front { clip-path: inset(50% 0 0 0); }
  /* Ellipse trick: a full-width square, squashed with scaleY to the ring's
     aspect. A circle traced inside it becomes exactly the ring's ellipse. */
  .orbiter {
    position: absolute; left: 50%; top: 50%; width: 100%; aspect-ratio: 1;
    transform: translate(-50%, -50%) scaleY(0.26);
  }
  .orbit-spin { position: absolute; inset: 0; animation: orbit 26s linear infinite; }
  .orbit-spin b {
    position: absolute; top: 0; left: 50%; width: 9px; height: 9px;
    margin: -4.5px 0 0 -4.5px; border-radius: 50%;
    background: var(--accent-cool); box-shadow: 0 0 10px var(--accent-cool);
    /* Counter-rotate + un-squash so the dot stays round at every angle.
       Base transform keeps it round when animations are off (reduced motion). */
    transform: scaleY(3.846);
    animation: orbit-counter 26s linear infinite;
  }
  @keyframes orbit { to { transform: rotate(360deg); } }
  @keyframes orbit-counter {
    from { transform: rotate(0deg) scaleY(3.846); }
    to { transform: rotate(-360deg) scaleY(3.846); }
  }
  @media (max-width: 560px) {
    .hero { padding: 2.75rem 1.25rem 3.5rem; }
    .art { opacity: 0.85; }
  }
  h1 { font-size: clamp(3rem, 9vw, 5.2rem); margin: 0.9rem 0 0; position: relative; z-index: 2; }
  h1 span { color: var(--accent); }
  .tag { max-width: 30rem; margin-top: 1.1rem; color: var(--text-dim); position: relative; z-index: 2; }
  .cta {
    display: inline-block; margin-top: 1.4rem; background: var(--accent); color: var(--bg);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.75rem;
    padding: 0.85rem 1.5rem; border-radius: 4px; text-decoration: none;
    position: relative; z-index: 2; transition: background 0.2s ease;
  }
  .cta:hover { background: var(--accent-bright); color: var(--bg); }
</style>
